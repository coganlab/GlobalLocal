  [NaN filter] class=0 stratum=Stimulus_c_MI_MR: 84 → 28 trials (66.7% dropped)
  [NaN filter] class=0 stratum=Stimulus_c_MI_MS: 84 → 28 trials (66.7% dropped)
  [NaN filter] class=0 stratum=Stimulus_c_MC_MR: 84 → 84 trials (0.0% dropped)
