  [NaN filter] class=1 stratum=Stimulus_i_MC_MR: 84 → 28 trials (66.7% dropped)
  [NaN filter] class=1 stratum=Stimulus_i_MC_MS: 84 → 28 trials (66.7% dropped)
  [class totals after stratum balancing] {0: 224, 1: 224}
  [balance_method=subsample] subsampling each class to 224
  [final] data shape: (448, 9, 641), labels: {np.int64(0): np.int64(224), np.int64(1): np.int64(224)}
